# Maintainer: instantOS <hello@instantos.io>
pkgname=instantwm
pkgver=0.1.14
pkgrel=1
pkgdesc="A tiling window manager for X11 and Wayland"
arch=('x86_64')
url="https://instantos.io"
license=('MIT')
depends=(
    'libx11'
    'libxcb'
    'libxkbcommon'
    'libxcursor'
    'libxinerama'
    'libxrandr'
    'libxss'
    'libxtst'
    'libxfixes'
    'libxdamage'
    'libxcomposite'
    'libxrender'
    'libxft'
    'libxi'
    'libxres'
    'libxvmc'
    'libxxf86vm'
    'libxt'
    'libxmu'
    'libxpm'
    'libxaw'
    'fontconfig'
    'freetype2'
    'libdrm'
    'mesa'
    'wayland'
    'libinput'
    'seatd'
    'libglvnd'
    'libevdev'
    'libwacom'
    'dbus'
    'systemd'
)
source=(
    "$pkgname-$pkgver.tar.gz::https://github.com/instantOS/instantWM/archive/refs/tags/v$pkgver.tar.gz"
    "$pkgname-x86_64-unknown-linux-gnu-v$pkgver.tgz::https://github.com/instantOS/instantWM/releases/download/v$pkgver/instantwm-x86_64-unknown-linux-gnu-v$pkgver.tgz"
)
sha256sums=(
    'aedc821abab28850e28e09bbc7d930daab399c21fb65aeb5a5c28f264ce1f705'
    '0446c577dca6c3e84319434622db296dd91a9f0de7edb3d94adc51533a6ffecd'
)

package() {
    cd "instantWM-$pkgver"

    # Binaries
    install -Dm755 "$srcdir/instantwm-x86_64-unknown-linux-gnu-v$pkgver/instantwm" "$pkgdir/usr/bin/instantwm"
    install -Dm755 "$srcdir/instantwm-x86_64-unknown-linux-gnu-v$pkgver/instantwmctl" "$pkgdir/usr/bin/instantwmctl"

    # License
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"

    # X11 session
    install -Dm644 utils/instantwm-x11.desktop "$pkgdir/usr/share/xsessions/instantwm.desktop"

    # Wayland session
    install -Dm644 utils/instantwm-wayland.desktop "$pkgdir/usr/share/wayland-sessions/instantwm-wayland.desktop"

    # Portal routing for Wayland screen sharing/screenshot support
    install -Dm644 resources/instantwm-portals.conf "$pkgdir/usr/share/xdg-desktop-portal/instantwm-portals.conf"
}
